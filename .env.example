# ---------------------------------------------------------------------------
# ColdWave environment configuration
# Copy to `.env` and fill in. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Database (Neon Postgres) ---
# Neon pooled connection string (used by the app at runtime)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/coldwave?sslmode=require

# --- Auth (NextAuth / Auth.js — self-hosted, no external keys) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-openssl-rand-base64-32
# Set to true behind HTTPS in production
AUTH_TRUST_HOST=true

# --- Encryption (AES-256-GCM for mailbox credentials at rest) ---
# Must be 32 bytes, base64 encoded. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=replace-with-openssl-rand-base64-32

# --- Redis (BullMQ job queues) ---
REDIS_URL=redis://localhost:6379

# --- Apollo.io (lead generation) ---
APOLLO_API_KEY=your-apollo-api-key

# --- OpenAI (AI campaign + funnel designer) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Stripe (billing, metered) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_EMAILS=price_...
STRIPE_PRICE_ID_LEADS=price_...

# --- System / transactional mail (app notifications only, NOT campaigns) ---
# Campaign sending uses each org's own connected mailboxes (SMTP/IMAP).
# This is only for password resets, billing receipts, internal alerts.
SYSTEM_SMTP_HOST=
SYSTEM_SMTP_PORT=587
SYSTEM_SMTP_USER=
SYSTEM_SMTP_PASS=
SYSTEM_MAIL_FROM="ColdWave <no-reply@yourdomain.com>"

# --- Compliance (CAN-SPAM requires a physical postal address in every email) ---
# This can also be set per-org in the app; used as the default fallback.
COMPANY_NAME=Your Company, Inc.
COMPANY_ADDRESS=123 Example St, Suite 100, City, ST 00000, USA

# --- Spam engine (SpamAssassin sidecar via spamc protocol) ---
SPAMASSASSIN_HOST=127.0.0.1
SPAMASSASSIN_PORT=783
# Block sending when spam score >= this (0-10 scale)
SPAM_SCORE_BLOCK_THRESHOLD=5
